{
  "name": "@datasynx/agentic-crm",
  "version": "0.1.0",
  "description": "Local-first, MCP-native CRM. One agent per customer. npm install.",
  "type": "module",
  "license": "MIT",
  "author": "Datasynx Engineering <eng@datasynx.io>",
  "keywords": [
    "crm",
    "mcp",
    "model-context-protocol",
    "local-first",
    "ai-agent",
    "claude",
    "cli",
    "sales",
    "lancedb"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datasynx-ai/datasynx-crm.git"
  },
  "homepage": "https://github.com/datasynx-ai/datasynx-crm#readme",
  "bugs": {
    "url": "https://github.com/datasynx-ai/datasynx-crm/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./mcp": {
      "import": {
        "types": "./dist/mcp.d.ts",
        "default": "./dist/mcp.js"
      },
      "require": {
        "types": "./dist/mcp.d.cts",
        "default": "./dist/mcp.cjs"
      }
    }
  },
  "bin": {
    "dxcrm": "./dist/cli.js",
    "datasynx-opencrm": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown && node scripts/postbuild.js",
    "docs:generate": "tsx scripts/generate-docs.ts",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.types.json",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src __tests__",
    "format:check": "prettier --check src __tests__",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "semantic-release",
    "prepublishOnly": "npm run typecheck && npm test && npm run build && npx publint && npx attw --pack . --ignore-rules no-resolution",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@googleapis/calendar": "15.0.0",
    "@googleapis/gmail": "17.0.0",
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.29.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "adm-zip": "^0.5.17",
    "ansis": "^3.0.0",
    "apache-arrow": "^17.0.0",
    "chokidar": "^4.0.0",
    "cli-table3": "^0.6.3",
    "commander": "^14.0.0",
    "cron": "^4.4.0",
    "google-auth-library": "10.6.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "slug": "^9.0.0",
    "zod": "^3.25.0",
    "zod-validation-error": "^3.0.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^5.0.6",
    "@types/iarna__toml": "^2.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/slug": "^5.0.0",
    "@types/which": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "expect-type": "^1.3.0",
    "husky": "^9.1.7",
    "license-checker": "^25.0.1",
    "lint-staged": "^17.0.5",
    "memfs": "^4.0.0",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.12.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
